  "scripts": {
    "setup": "node ./scripts/setup.mjs",
    "setup:classic": "node ./scripts/setup.mjs --classic",
    "setup:reinstall": "node ./scripts/setup.mjs --reinstall",
    "setup:reinstall:classic": "node ./scripts/setup.mjs --reinstall --classic",
    "dev": "node ./scripts/dev.mjs",
    "dev:classic": "node ./scripts/dev.mjs --classic",
    "dev:verbose": "node ./scripts/dev.mjs --verbose",
    "dev:reset": "node ./scripts/dev-reset.mjs",
    "build": "yarn generate && next build",
    "start": "mercato server start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "jest --config jest.config.cjs",
    "test:integration": "npx playwright test --config .ai/qa/tests/playwright.config.ts",
