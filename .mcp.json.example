{
  "_comment": "Copy to .mcp.json and set MCP_API_KEY (printed by yarn initialize)",
  "mcpServers": {
    "open-mercato": {
      "command": "yarn",
      "args": ["mercato", "mcp:dev"],
      "env": {
        "APP_URL": "http://localhost:3000",
        "MCP_API_KEY": "${MCP_API_KEY}"
      }
    }
  }
}
