# Example environment configuration
# Copy this file to .env and adjust values for your environment.

# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=open-mercato
POSTGRES_PORT=5432

# PostgreSQL connection string (required)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/open-mercato

# JWT secret for auth tokens (required)
JWT_SECRET=change-me-dev-secret
# Session/cookie signing secret used by auth flows and checkout password sessions.
# Preferred over JWT_SECRET when set.
AUTH_SECRET=change-me-dev-auth-secret
# Optional alias used by some NextAuth/Auth.js setups.
NEXTAUTH_SECRET=

# Events transport (choose one)
# REDIS_URL=redis://localhost:6379
# or
# EVENTS_REDIS_URL=redis://localhost:6379

# Email provider (optional)
# RESEND_API_KEY=

# Public URL used in emails and onboarding flows
APP_URL=http://localhost:3000
# Additional trusted origins for app requests that must pass host validation.
# APP_URL is required in production for security-sensitive email links.
# Example: APP_ALLOWED_ORIGINS=https://admin.example.com,https://ops.example.com
# APP_ALLOWED_ORIGINS=

# Enable self-service onboarding (default: false)
SELF_SERVICE_ONBOARDING_ENABLED=false
# Enable Open Mercato demo widgets (default: false)
DEMO_MODE=false

# Enable enterprise-only optional modules (default: false)
# Developer preview is free for local/dev usage.
# Production usage requires a commercial enterprise license.
# Details: https://github.com/open-mercato/open-mercato/blob/main/packages/enterprise/README.md
OM_ENABLE_ENTERPRISE_MODULES=false
# Enable enterprise SSO module (default: false)
# Requires OM_ENABLE_ENTERPRISE_MODULES=true
OM_ENABLE_ENTERPRISE_MODULES_SSO=false

# Enterprise security module (MFA, passkeys, sudo)
# Active when enterprise modules are enabled and the security module is installed.
# Optional dedicated signing secret for MFA setup tokens.
# Falls back to AUTH_JWT_SECRET, AUTH_SECRET, or JWT_SECRET when left blank.
# Enable enterprise security module (default: false)
# Requires OM_ENABLE_ENTERPRISE_MODULES=true
OM_ENABLE_ENTERPRISE_MODULES_SECURITY=false

# Enable the S3-compatible storage provider module (default: false).
# When true, `storage_s3` is added to enabledModules in modules.ts and the
# Integration Marketplace exposes the "S3 Object Storage" card.
# The provider can also be preconfigured from env vars — see the
# "S3 Storage Preconfiguration" block at the bottom of this file.
OM_ENABLE_STORAGE_S3=false

# OM_SECURITY_MFA_SETUP_SECRET=change-me-mfa-setup-secret
OM_SECURITY_TOTP_ISSUER=Open Mercato
OM_SECURITY_TOTP_WINDOW=1
OM_SECURITY_OTP_EXPIRY_SECONDS=600
OM_SECURITY_OTP_MAX_ATTEMPTS=5
OM_SECURITY_SUDO_DEFAULT_TTL=300
OM_SECURITY_SUDO_MAX_TTL=1800
OM_SECURITY_WEBAUTHN_RP_NAME=Open Mercato
# Defaults to the hostname from APP_URL / NEXT_PUBLIC_APP_URL when left blank.
OM_SECURITY_WEBAUTHN_RP_ID=
OM_SECURITY_RECOVERY_CODE_COUNT=10
OM_SECURITY_MFA_EMERGENCY_BYPASS=false

# Outgoing email sender priority:
# 1. NOTIFICATIONS_EMAIL_FROM
# 2. EMAIL_FROM
# 3. ADMIN_EMAIL
NOTIFICATIONS_EMAIL_FROM=
EMAIL_FROM=

# Admin email to notify about onboarding submissions.
# Also used as the final sender fallback when the sender-specific vars above are empty.
ADMIN_EMAIL=ops@your-domain.com

# UMES DevTools panel (default: true)
# Enables the Ctrl+Shift+U keyboard shortcut to open the UMES DevTools panel.
# Set to false in production deployments where DevTools should be hidden.
NEXT_PUBLIC_UMES_DEVTOOLS=true

# Example checkout pay-page test injections (default: false)
# Enables checkout summary/help wrappers used by integration tests only.
NEXT_PUBLIC_OM_EXAMPLE_CHECKOUT_TEST_INJECTIONS_ENABLED=false

# Public date/time display format overrides (date-fns tokens).
# Leave unset, or set to "system", to use the locale-derived default.
# Examples: NEXT_PUBLIC_OM_DATE_FORMAT=dd.MM.yyyy
#           NEXT_PUBLIC_OM_DATE_TIME_FORMAT=dd.MM.yyyy HH:mm
# NEXT_PUBLIC_OM_DATE_FORMAT=
# NEXT_PUBLIC_OM_DATE_TIME_FORMAT=

# Mock payment gateway webhook secret used by the example mock provider.
# Required for webhook verification in standalone integration and local test flows.
# MOCK_GATEWAY_WEBHOOK_SECRET=open-mercato-mock-dev-webhook-secret

# Mock shipping carrier webhook secret used by the example mock carrier adapter.
# Required for webhook verification in standalone integration and local test flows.
# MOCK_CARRIER_WEBHOOK_SECRET=open-mercato-mock-dev-carrier-webhook-secret

# Checkout origin allowlist (optional, comma-separated)
# Extra origins allowed to submit payments via the public pay-link endpoint.
# By default, only the server's own origin (derived from the request URL,
# Host, X-Forwarded-Host and X-Forwarded-Proto headers) is accepted.
# Use this when the pay page is served from a different domain than the API
# (e.g. a custom storefront or CDN domain).
# Example: CHECKOUT_ALLOWED_ORIGINS=https://shop.example.com,https://pay.example.com
# CHECKOUT_ALLOWED_ORIGINS=

# Rate limiting is enabled by default. Auth endpoints (login/signup/reset)
# cap at 5–20 requests/minute which is normally fine in dev, but can bite
# when running integration tests against a long-lived dev server. Set
# OM_INTEGRATION_TEST=true to disable rate limiting globally for test runs.
# See: apps/docs/docs/framework/security/rate-limiting.mdx
# OM_INTEGRATION_TEST=false

# Auto-spawn workers when starting the app (default: true)
# Set to false to run workers separately in production
AUTO_SPAWN_WORKERS=true

# Base directory for local file-backed queues (default: ./.mercato/queue)
QUEUE_BASE_DIR=./.mercato/queue

# SSL Certificate Configuration
# Path to additional CA certificates for Node.js HTTPS connections
# Required for Raiffeisen Bank API which doesn't send complete certificate chain
# The GeoTrust EV RSA CA G2 intermediate certificate is needed for SSL verification
# Certificate valid until: July 2, 2030
# To update: curl -o certs/geotrust-ev-rsa-ca-g2.pem https://cacerts.digicert.com/GeoTrustEVRSACAG2.crt.pem
#NODE_EXTRA_CA_CERTS=./certs/geotrust-ev-rsa-ca-g2.pem

# Hybrid query engine SQL logging (optional, default: false)
# Set to true to log raw SQL statements from the hybrid query engine.
QUERY_ENGINE_DEBUG_SQL=false

# Enable tree profiler for matching resources/entities (comma-separated filters, e.g. * - for all profilers,customers.*, customers.people)
# OM_PROFILE=
# Enable detailed CRUD profiling for matching resources (comma-separated filters, e.g. customers.*, *)
# OM_CRUD_PROFILE=
# Enable hybrid query engine profiling for matching entities (comma-separated filters, e.g. customers.*, customers.people)
# OM_QE_PROFILE=

# Enable cache for CRUD API responses (default: false)
ENABLE_CRUD_API_CACHE=false

# Auto-reindex query indexes when coverage gaps are detected (default: true)
SCHEDULE_AUTO_REINDEX=true

# Skip immediate coverage recalculation on read (default: false)
OPTIMIZE_INDEX_COVERAGE_STATS=false

# Continue serving results from entity indexes when coverage gaps are detected (default: true)
FORCE_QUERY_INDEX_ON_PARTIAL_INDEXES=true

# Hashed search tokenization defaults
OM_SEARCH_ENABLED=true
OM_SEARCH_MIN_LEN=3
OM_SEARCH_ENABLE_PARTIAL=true
OM_SEARCH_HASH_ALGO=sha256
OM_SEARCH_STORE_RAW_TOKENS=false
# Optional comma-separated blocklist of field name substrings to skip during tokenization
# OM_SEARCH_FIELD_BLOCKLIST=password,token,secret,hash

# Search module debug logging (Meilisearch, vector search, reindex operations)
OM_SEARCH_DEBUG=false

# Query index engine debug logging (search:source-has-tokens, coverage, etc.)
OM_QUERY_INDEX_DEBUG=false

# Toggle EAV backward compatibility for user-defined entities (custom field values)
# When true, DataEngine will also write to custom_field_values on create/update of custom entities.
# Default is false: values are only stored in custom_entities_storage.
ENTITIES_BACKCOMPAT_EAV_FOR_CUSTOM=false

# Cache strategy (default: memory)
CACHE_STRATEGY=sqlite

# Default TTL in milliseconds (optional)
CACHE_TTL=300000

# Redis Configuration
#REDIS_PORT=6379

# Redis configuration (for redis strategy)
#CACHE_REDIS_URL=redis://localhost:6379

# SQLite configuration (for sqlite strategy)
CACHE_SQLITE_PATH=./.mercato/cache/cache.db

# JSON file configuration (for jsonfile strategy)
#CACHE_JSON_FILE_PATH=./.mercato/cache/cache.json

# Database pooling settings
DB_POOL_MIN=5
# Conservative local/dev default. Increase explicitly for higher-concurrency deployments.
DB_POOL_MAX=20
DB_POOL_IDLE_TIMEOUT=30000
DB_POOL_ACQUIRE_TIMEOUT=60000

# Audit log retention windows
# Core resources (users, roles) keep access history longer to support investigations.
AUDIT_LOGS_CORE_RETENTION_DAYS=7
# Non-core reads rotate aggressively to limit storage.
AUDIT_LOGS_NON_CORE_RETENTION_HOURS=8

# Tenant data encryption (enabled by default)
TENANT_DATA_ENCRYPTION=yes
TENANT_DATA_ENCRYPTION_DEBUG=false
# Preferred fallback key when Vault is unavailable (use a strong 32+ char secret)
TENANT_DATA_ENCRYPTION_FALLBACK_KEY=dev-tenant-encryption-fallback-key-32chars
# Legacy secondary fallback secret (optional)
TENANT_DATA_ENCRYPTION_KEY=
# Dedicated high-entropy pepper used to key lookup hashes (email_hash, external_email_hash, …)
# so they cannot be attacked with offline rainbow tables or correlated across installations
# (issue #2718). When unset, the encryption fallback/legacy keys above are used; if none are
# configured the lookup hash falls back to the legacy unkeyed digest. Never reuse AUTH_SECRET here.
LOOKUP_HASH_PEPPER=
# HashiCorp Vault configuration (disabled by default in local dev).
# Uncomment only if you actually run Vault locally; otherwise the fallback key above
# is used immediately.
# VAULT_ADDR=http://localhost:8200
# VAULT_TOKEN=dev-only-token
# VAULT_KV_PATH=secret/data
# Bound per-request deadline for Vault KV reads/writes so a degraded Vault
# does not stall encryption/decryption across the platform (default: 1000 ms).
# VAULT_REQUEST_TIMEOUT_MS=1000

# ============================================================================
# AI Providers, OCR, and Vector Search
# ============================================================================
# New apps ship with AI providers disabled. The unified AI module reads the
# `OM_AI_*` variables below first; the legacy `OPENCODE_*` aliases stay
# supported as a backward-compatibility fallback when `OM_AI_*` is unset.
# Defaults target OpenAI + `gpt-5-mini` — set `OPENAI_API_KEY` (and any
# overrides you want) to enable the AI Assistant.
# Docs:
# - AI Assistant: https://docs.openmercato.com/framework/ai-assistant/overview
# - AI settings: https://docs.openmercato.com/framework/ai-assistant/settings
# - Search/vector embeddings: https://docs.openmercato.com/user-guide/search

# AI Assistant provider selection (unified). Built-in ids: openai, anthropic,
# google, deepinfra, groq, together, fireworks, azure, litellm, ollama.
# The legacy `OPENCODE_PROVIDER` is still honored as a fallback when this is unset.
OM_AI_PROVIDER=openai

# AI Assistant model id. Format: `<provider>/<model>` or bare `<model>`
# (the dispatcher fills in the provider from OM_AI_PROVIDER). Defaults to
# `gpt-5-mini` to pair with `OM_AI_PROVIDER=openai`. Examples:
#   openai/gpt-5-mini
#   anthropic/claude-haiku-4-5-20251001
#   deepinfra/zai-org/GLM-5.1
#   meta-llama/Llama-3.3-70B-Instruct-Turbo
OM_AI_MODEL=gpt-5-mini

# Per-module overrides (Phase 1 of the per-axis-overrides spec). When set,
# they win over the global `OM_AI_PROVIDER` / `OM_AI_MODEL` for the matching
# module's agent runs. Examples (uppercased from the agent's moduleId):
#   OM_AI_CATALOG_PROVIDER=openai
#   OM_AI_CATALOG_MODEL=openai/gpt-5-mini
#   OM_AI_INBOX_OPS_PROVIDER=anthropic
#   OM_AI_INBOX_OPS_MODEL=claude-haiku-4-5
# The legacy `<MODULE>_AI_MODEL` / `<MODULE>_AI_PROVIDER` forms are honored
# as backward-compatibility fallbacks.

# Provider / model ALLOWLIST. Operator-defined hard ceiling on what
# (provider, model) the runtime accepts. Unset / empty → no restriction.
# When set, the settings UI, chat-UI picker, dispatcher query params, and
# model-factory all clip to this subset (with `console.warn` + a safe
# fallback whenever a higher-priority source resolves to a blocked value).
#
#   OM_AI_AVAILABLE_PROVIDERS=openai,anthropic
#   OM_AI_AVAILABLE_MODELS_OPENAI=gpt-5-mini,gpt-5
#   OM_AI_AVAILABLE_MODELS_ANTHROPIC=claude-haiku-4-5,claude-opus-4-7
# OM_AI_AVAILABLE_PROVIDERS=
# OM_AI_AVAILABLE_MODELS_OPENAI=
# OM_AI_AVAILABLE_MODELS_ANTHROPIC=
#
# Per-agent chat override picker allowlist. This narrows only the models a
# user may pick in the chat footer for that agent; it does not change the
# default model. Agent id is uppercased and punctuation becomes `_`.
#   OM_AI_AGENT_CATALOG_CATALOG_ASSISTANT_AVAILABLE_PROVIDERS=openai,lm-studio
#   OM_AI_AGENT_CATALOG_CATALOG_ASSISTANT_AVAILABLE_MODELS_OPENAI=gpt-5-mini,gpt-4o

# Optional process-wide model default for the new typed-agent runtime.
# Slash-qualified ids (e.g. openai/gpt-5-mini) consume the provider axis
# at the same step. Examples:
# OpenAI API key — REQUIRED to enable the AI Assistant when
# `OM_AI_PROVIDER=openai` (the default). Get one at https://platform.openai.com/api-keys.
OPENAI_API_KEY=
OPENCODE_OPENAI_API_KEY=

# Legacy AI provider/model variables. Kept ONLY for backward compatibility —
# the unified runtime reads `OM_AI_PROVIDER` / `OM_AI_MODEL` first and falls
# back to these when the new variables are unset. New deployments should
# leave them blank.
# OPENCODE_PROVIDER=
# OPENCODE_MODEL=

# Additional native LLM providers. Leave blank until you intentionally
# configure one and set `OM_AI_PROVIDER` to the matching id.
# anthropic: set OM_AI_PROVIDER=anthropic + ANTHROPIC_API_KEY
ANTHROPIC_API_KEY=
OPENCODE_ANTHROPIC_API_KEY=
# google: set OM_AI_PROVIDER=google + GOOGLE_GENERATIVE_AI_API_KEY
GOOGLE_GENERATIVE_AI_API_KEY=
OPENCODE_GOOGLE_API_KEY=

# OpenAI-compatible LLM providers.
# deepinfra/groq/together/fireworks: set OM_AI_PROVIDER to the provider id
# and fill the matching *_API_KEY below.
DEEPINFRA_API_KEY=
# DEEPINFRA_BASE_URL=
GROQ_API_KEY=
# GROQ_BASE_URL=
TOGETHER_API_KEY=
# TOGETHER_BASE_URL=
FIREWORKS_API_KEY=
# FIREWORKS_BASE_URL=
# azure/litellm/ollama: set OM_AI_PROVIDER to the provider id and fill
# the API key plus base URL when that backend requires one.
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=
LITELLM_API_KEY=
LITELLM_BASE_URL=
OLLAMA_API_KEY=
OLLAMA_BASE_URL=
# OpenRouter — unified API gateway (hundreds of models via one key).
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=
# LM Studio — local model server (auto-detects loaded model when LM_STUDIO_API_KEY is set).
# LM_STUDIO_API_KEY=
# LM_STUDIO_BASE_URL=
# Override the OpenAI base URL (e.g. for a Cloudflare AI Gateway proxy).
# OPENAI_BASE_URL=

# Embedding-only providers for vector search.
MISTRAL_API_KEY=
COHERE_API_KEY=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=

# Vector search automatic indexing ships disabled by default. After setting an
# embedding provider key above, enable this and trigger a vector reindex from
# Settings > Search or the CLI.
OM_DISABLE_VECTOR_SEARCH_AUTOINDEXING=true
# Legacy alias still supported: DISABLE_VECTOR_SEARCH_AUTOINDEXING=1
# Optional request cap for embedding providers (default: 3000 ms).
# VECTOR_EMBEDDING_TIMEOUT_MS=3000

# OCR model for image and PDF text extraction. OCR currently requires
# OPENAI_API_KEY to be set above.
OCR_MODEL=gpt-4o
# OCR_DEFAULT_PROMPT="Extract all text content from this image..."
# OPENMERCATO_DEFAULT_ATTACHMENT_OCR_ENABLED=true

# Outbound request timeouts for the AI Assistant / OpenCode stack.
# OPENCODE_REQUEST_TIMEOUT_MS=30000
# OPENCODE_SSE_CONNECT_TIMEOUT_MS=15000
# OPENCODE_SEND_MESSAGE_TIMEOUT_MS=
# AI_API_REQUEST_TIMEOUT_MS=30000
# AI_OPENAPI_FETCH_TIMEOUT_MS=10000

# ============================================================================
# Stripe Integration Preconfiguration
# ============================================================================
# If these values are set, the Stripe provider can preconfigure itself during
# tenant setup and can be rerun later with:
# yarn mercato gateway_stripe configure-from-env --tenant <tenantId> --org <organizationId>
#
# Required for auto-preconfiguration:
# OM_INTEGRATION_STRIPE_PUBLISHABLE_KEY=pk_test_...
# OM_INTEGRATION_STRIPE_SECRET_KEY=sk_test_...
# OM_INTEGRATION_STRIPE_WEBHOOK_SECRET=whsec_...
#
# Optional behavior:
# OM_INTEGRATION_STRIPE_API_VERSION=2025-02-24.acacia
# OM_INTEGRATION_STRIPE_ENABLED=true
# OM_INTEGRATION_STRIPE_FORCE_PRECONFIGURE=false
#
# Notes:
# - Use publishable, secret, and webhook keys from the same Stripe mode.
# - The preset pins the default Stripe API version if you do not set one.
# - Legacy aliases OPENMERCATO_STRIPE_* and STRIPE_* still work.
# OM_INTEGRATION_STRIPE_PUBLISHABLE_KEY=
# OM_INTEGRATION_STRIPE_SECRET_KEY=
# OM_INTEGRATION_STRIPE_WEBHOOK_SECRET=
# OM_INTEGRATION_STRIPE_API_VERSION=2025-02-24.acacia
# OM_INTEGRATION_STRIPE_ENABLED=true
# OM_INTEGRATION_STRIPE_FORCE_PRECONFIGURE=false

# ============================================================================
# Akeneo Sync Preconfiguration
# ============================================================================
# If these credentials are set, the Akeneo provider can preconfigure itself
# during tenant setup and can be rerun later with:
# yarn mercato sync_akeneo configure-from-env --tenant <tenantId> --org <organizationId>
#
# Required for auto-preconfiguration:
# OM_INTEGRATION_AKENEO_API_URL=https://your-instance.cloud.akeneo.com
# OM_INTEGRATION_AKENEO_CLIENT_ID=
# OM_INTEGRATION_AKENEO_CLIENT_SECRET=
# OM_INTEGRATION_AKENEO_USERNAME=
# OM_INTEGRATION_AKENEO_PASSWORD=
#
# Optional behavior:
# OM_INTEGRATION_AKENEO_FORCE_PRECONFIGURE=false
# OM_INTEGRATION_AKENEO_PRODUCT_LOCALE=en_US
# OM_INTEGRATION_AKENEO_CATEGORY_LOCALE=en_US
# OM_INTEGRATION_AKENEO_PRODUCT_CHANNEL=ecommerce
# OM_INTEGRATION_AKENEO_IMPORT_CHANNELS=ecommerce,mobile
# OM_INTEGRATION_AKENEO_IMPORT_ALL_CHANNELS=true
# OM_INTEGRATION_AKENEO_CREATE_MISSING_CHANNELS=true
# OM_INTEGRATION_AKENEO_SYNC_ASSOCIATIONS=true
# OM_INTEGRATION_AKENEO_ATTRIBUTE_FAMILY_FILTER=clothing,cameras
#
# Advanced JSON overrides:
# OM_INTEGRATION_AKENEO_PRODUCTS_SETTINGS_JSON={"settings":{"products":{"subtitleAttribute":"short_description"}}}
# OM_INTEGRATION_AKENEO_CATEGORIES_SETTINGS_JSON={"locale":"en_US"}
# OM_INTEGRATION_AKENEO_ATTRIBUTES_SETTINGS_JSON={"settings":{"attributes":{"familyCodeFilter":["clothing"]}}}
#
# Security:
# The Akeneo client validates API URLs server-side to prevent SSRF and credential
# exfiltration. By default only *.cloud.akeneo.com and *.akeneo.cloud hosts are
# allowed. Override the allowlist for self-hosted or private instances:
# OM_INTEGRATION_AKENEO_ALLOWED_HOSTS=pim.example.internal,akeneo.corp.local
# Aliases (checked in priority order): OM_INTEGRATION_AKENEO_ALLOWED_HOSTS,
#   OPENMERCATO_AKENEO_ALLOWED_HOSTS, AKENEO_ALLOWED_HOSTS
#
# Notes:
# - Only one product locale is imported into base Open Mercato fields at a time.
# - OM_INTEGRATION_AKENEO_IMPORT_CHANNELS is comma-separated.
# - Legacy aliases OPENMERCATO_AKENEO_* and AKENEO_* still work.
# - Leave the block commented out when Akeneo should not be preconfigured.
# OM_INTEGRATION_AKENEO_API_URL=
# OM_INTEGRATION_AKENEO_CLIENT_ID=
# OM_INTEGRATION_AKENEO_CLIENT_SECRET=
# OM_INTEGRATION_AKENEO_USERNAME=
# OM_INTEGRATION_AKENEO_PASSWORD=
# OM_INTEGRATION_AKENEO_ALLOWED_HOSTS=
# OM_INTEGRATION_AKENEO_FORCE_PRECONFIGURE=false
# OM_INTEGRATION_AKENEO_PRODUCT_LOCALE=
# OM_INTEGRATION_AKENEO_CATEGORY_LOCALE=
# OM_INTEGRATION_AKENEO_PRODUCT_CHANNEL=
# OM_INTEGRATION_AKENEO_IMPORT_CHANNELS=
# OM_INTEGRATION_AKENEO_IMPORT_ALL_CHANNELS=true
# OM_INTEGRATION_AKENEO_CREATE_MISSING_CHANNELS=true
# OM_INTEGRATION_AKENEO_SYNC_ASSOCIATIONS=true
# OM_INTEGRATION_AKENEO_ATTRIBUTE_FAMILY_FILTER=
# OM_INTEGRATION_AKENEO_PRODUCTS_SETTINGS_JSON=
# OM_INTEGRATION_AKENEO_CATEGORIES_SETTINGS_JSON=
# OM_INTEGRATION_AKENEO_ATTRIBUTES_SETTINGS_JSON=

# ============================================================================
# S3 Storage Preconfiguration
# ============================================================================
# If these credentials are set, the storage_s3 provider preconfigures itself
# during tenant setup and can be rerun later (for existing tenants) with:
# yarn mercato storage_s3 configure-from-env --tenant <tenantId> --org <organizationId>
#
# For unattended deploys (Dokploy, Coolify, Kamal, etc.), use --all-tenants
# as a post-deploy hook to apply the preset to every active organization
# without tracking UUIDs in your deploy config:
# yarn mercato storage_s3 configure-from-env --all-tenants
#
# The CLI exits non-zero on an incomplete preset so CI/automation can detect
# misconfiguration. Pass --force (or set OM_INTEGRATION_STORAGE_S3_FORCE_PRECONFIGURE=true)
# to overwrite credentials that have already been stored for the tenant.
#
# The module itself is only loaded when OM_ENABLE_STORAGE_S3=true (see above)
# — without that flag the preconfiguration block below is ignored.
#
# Required for auto-preconfiguration:
# OM_INTEGRATION_STORAGE_S3_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
# OM_INTEGRATION_STORAGE_S3_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY
# OM_INTEGRATION_STORAGE_S3_REGION=eu-central-1
# OM_INTEGRATION_STORAGE_S3_BUCKET=my-mercato-attachments
#
# Optional behavior:
# OM_INTEGRATION_STORAGE_S3_SESSION_TOKEN=
# OM_INTEGRATION_STORAGE_S3_ENDPOINT=https://fra1.digitaloceanspaces.com
# OM_INTEGRATION_STORAGE_S3_FORCE_PATH_STYLE=false
# OM_INTEGRATION_STORAGE_S3_FORCE_PRECONFIGURE=false
#
# Notes:
# - SESSION_TOKEN is only needed for short-lived STS credentials.
# - Leave ENDPOINT blank for AWS S3. Set it for MinIO, DigitalOcean Spaces,
#   Cloudflare R2, Backblaze B2, etc.
# - FORCE_PATH_STYLE must be true for MinIO and most self-hosted S3 services.
# - Leave the block commented out when S3 should not be preconfigured.
# OM_INTEGRATION_STORAGE_S3_ACCESS_KEY_ID=
# OM_INTEGRATION_STORAGE_S3_SECRET_ACCESS_KEY=
# OM_INTEGRATION_STORAGE_S3_REGION=
# OM_INTEGRATION_STORAGE_S3_BUCKET=
# OM_INTEGRATION_STORAGE_S3_SESSION_TOKEN=
# OM_INTEGRATION_STORAGE_S3_ENDPOINT=
# OM_INTEGRATION_STORAGE_S3_FORCE_PATH_STYLE=false
# OM_INTEGRATION_STORAGE_S3_FORCE_PRECONFIGURE=false

# ============================================================================
# InboxOps Configuration (email-to-ERP agent)
# ============================================================================
# HMAC secret for validating inbound email webhooks (required for InboxOps)
# INBOX_OPS_WEBHOOK_SECRET=
# Resend webhook signing secret (whsec_... from Resend webhook dashboard)
# Required if using Resend's native inbound email webhooks
# RESEND_WEBHOOK_SIGNING_SECRET=whsec_...
# Domain used for generating inbox forwarding addresses
# INBOX_OPS_DOMAIN=inbox.mercato.local
# Optional: Override default LLM model for email extraction
# INBOX_OPS_LLM_MODEL=
# LLM extraction timeout in milliseconds (default: 90000)
# INBOX_OPS_LLM_TIMEOUT_MS=90000
# Minimum confidence threshold for auto-review (default: 0.5)
# INBOX_OPS_CONFIDENCE_THRESHOLD=0.5
# Maximum email text size in bytes sent to LLM (default: 204800)
# INBOX_OPS_MAX_TEXT_SIZE=204800
# Price mismatch tolerance as decimal fraction (default: 0.05 = 5%)
# INBOX_OPS_PRICE_MISMATCH_THRESHOLD=0.05

# ============================================================================
# Meilisearch Configuration (for hybrid search)
# ============================================================================
# Meilisearch provides fast full-text fuzzy search capabilities.
# When configured, it becomes the primary search strategy.
# If not configured, the system falls back to token-based search.

# Meilisearch server URL (required for Meilisearch strategy)
# MEILISEARCH_HOST=http://localhost:7700

# Meilisearch API key (required for production, optional for development)
# MEILISEARCH_API_KEY=your_master_key_here

# Index prefix for tenant isolation (default: om)
# MEILISEARCH_INDEX_PREFIX=om

# ============================================================================
# Customer Portal Custom Domain (Phase 1–3)
# ============================================================================
# See .ai/specs/2026-04-08-portal-custom-domain-routing.md and
# docker/traefik/README.md. Required when custom-domain mappings are in use.

# Primary platform host — excluded from the Traefik domain-check middleware
# and treated as the platform pass-through host by the Node middleware.
PLATFORM_PRIMARY_HOST=openmercato.local

# Mandatory shared secret for /api/customer_accounts/domain-check
# (Traefik ForwardAuth gate). Generate with: openssl rand -hex 32
DOMAIN_CHECK_SECRET=

# Mandatory shared secret for the Node middleware's calls to
# /api/customer_accounts/domain-resolve. Generate with: openssl rand -hex 32
DOMAIN_RESOLVE_SECRET=

# Internal origin the proxy uses to call domain-resolve. Defaults to
# http://app:3000 inside docker; set to your local app for `yarn dev`.
INTERNAL_APP_ORIGIN=http://127.0.0.1:3000

# DNS targets surfaced to admins in the back office.
CUSTOM_DOMAIN_CNAME_TARGET=portal.openmercato.local
CUSTOM_DOMAIN_A_RECORD_TARGET=

# Optional cache tuning (defaults: 60 / 300 / 10000)
# DOMAIN_CACHE_TTL_SECONDS=60
# DOMAIN_NEGATIVE_CACHE_TTL_SECONDS=300
# DOMAIN_CACHE_MAX_ENTRIES=10000

# Optional override for the marker header set on /_next/health
# CUSTOMER_DOMAIN_ORIGIN_HEADER=X-Open-Mercato-Origin

# Background verification (Phase 5) — both workers are scheduled
# automatically by `mercato init` via the system scheduler.
# DNS auto-verification scan interval (default 300s = 5 min).
# DOMAIN_AUTO_VERIFY_INTERVAL_SECONDS=300
# TLS retry scan interval (default 1800s = 30 min).
# DOMAIN_TLS_RETRY_INTERVAL_SECONDS=1800
# Per-run cap for the TLS retry worker (default 50).
# DOMAIN_TLS_RETRY_BATCH=50
# Failure-rate threshold (0–1) that triggers worker-level backoff (default 0.8).
# DOMAIN_TLS_RETRY_FAILURE_THRESHOLD=0.8
# Maximum tls_retry_count before the worker stops retrying (default 6).
# DOMAIN_TLS_MAX_RETRIES=6

# --- Traefik (only for docker-compose.fullapp{,.dev}.yml) ---
# Let's Encrypt contact address.
ACME_EMAIL=
# Defaults to LE production. Dev compose defaults to LE staging.
# TRAEFIK_CA_SERVER=https://acme-staging-v02.api.letsencrypt.org/directory
# TRAEFIK_HTTP_PORT=80
# TRAEFIK_HTTPS_PORT=443
# TRAEFIK_DASHBOARD_PORT=8081

# --- Email / Communication Channels (per-user email integration) ---
# All optional. The two signing secrets fall back to KMS_MASTER_KEY (via HKDF)
# and only fail closed in production if neither they nor KMS_MASTER_KEY are set.
# HMAC key for inbound reply-threading tokens. Generate: openssl rand -hex 32
# OM_THREAD_TOKEN_SECRET=
# AES key for the per-user OAuth state cookie. Generate: openssl rand -hex 32
# OM_HUB_OAUTH_STATE_KEY=
# Inbound poll scheduler tick cadence (seconds).
# OM_HUB_POLL_SCHEDULER_TICK_SECONDS=60
# Gmail push (Pub/Sub) — leave unset to fall back to polling.
# OM_GMAIL_PUBSUB_TOPIC=
# OM_GMAIL_PUBSUB_AUDIENCE=
# OM_GMAIL_PUBSUB_SERVICE_ACCOUNT_EMAIL=
# Push-subscription renewal lead times (hours before expiry).
# OM_PUSH_RENEWAL_GMAIL_LEAD_HOURS=24
# IMAP/SMTP provider safety + tuning. Keep the two ALLOW_* off in production.
# OM_CHANNEL_IMAP_ALLOW_INSECURE_TRANSPORT=false
# OM_CHANNEL_IMAP_ALLOW_INTERNAL_HOSTS=false
# OM_CHANNEL_IMAP_HARD_CAP_PER_POLL=200
# OM_CHANNEL_IMAP_SOCKET_TIMEOUT_MS=60000

# --- Test-only Host spoof (NEVER set in production) ---
# Activates only when NODE_ENV=test. Used by Playwright to drive arbitrary
# Host values without DNS. Generate with: openssl rand -hex 32
# FORCE_HOST_SECRET=
